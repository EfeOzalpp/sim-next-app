// Database client and datasource configuration
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  STAFF
  ADMIN
}

// User model for authentication and profiles
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  accounts      Account[]
  sessions      Session[]
  name          String
  image         String    @default("/face.jpg")
  about         String?
  pronouns      String?
  link          String?
  role          Role      @default(STUDENT)  
  presentations Presentation[]
  productions   Production[]
  semesters     Semester[]
}

// Presentation model for tracking scheduled talks or demos
model Presentation {
  id            String      @id @default(cuid())
  name          String
  about         String?
  presenters    User[]
  production_id String?
  production    Production? @relation(fields: [production_id], references: [id], onDelete: Cascade)
}

// Production model representing a collection of presentations
model Production {
  id            String         @id @default(cuid())
  name          String
  location      String
  producers     User[]
  presentations Presentation[]
  thursday_id   String
  thursday      Thursday      @relation(fields: [thursday_id], references: [id], onDelete: Cascade)
}

// Thursday model for tracking weekly events
model Thursday {
  id          String       @id @default(cuid())
  date        DateTime
  name        String
  productions Production[]
  semester_id String?
  semester    Semester?    @relation(fields: [semester_id], references: [id], onDelete: Cascade)
}

// Semester model for grouping events by academic period
model Semester {
  id        String     @id @default(cuid())
  name      String
  thursdays Thursday[]
  users     User[]
}

// NextAuth Account model for OAuth provider linking
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

// NextAuth Session model for managing active user sessions
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
